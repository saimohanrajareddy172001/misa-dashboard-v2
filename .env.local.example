NEXT_PUBLIC_SUPABASE_URL=https://tzscbakslxdwgioksmya.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Restaurant is now picked at runtime via the switcher in the header.
# An owner with multiple restaurants will see all of them.

# Server-only — used by /api/parse-invoice (OpenAI gpt-4o-mini)
OPENAI_API_KEY=sk-...your-openai-key-here

# Server-only — used by /api/clover-sync (bypasses RLS to write pos_sales)
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here

# Server-only — used by /api/apify-sync (Run Now button on Settings page)
# Get APIFY_TOKEN at console.apify.com → Account → Integrations
# APIFY_ACTOR_ID is e.g. "yourusername/restaurant-depot-receipts"
APIFY_TOKEN=your-apify-token
APIFY_ACTOR_ID=yourusername/restaurant-depot-receipts
